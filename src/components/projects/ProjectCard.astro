---
interface Props {
    title: string;
    description: string;
    image: string;
    alt: string;
    tags: string[];
}

const { title, description, image, alt, tags } = Astro.props;
---

<div
    class="group flex flex-col p-6 rounded-xl bg-surface border border-border hover:border-primary/40 hover:-translate-y-1 shadow-sm hover:shadow-md transition-all duration-300"
>
    <div
        class="w-full aspect-video rounded-lg mb-6 overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-500"
    >
        <img
            src={image}
            alt={alt}
            loading="lazy"
            class="w-full h-full object-cover"
        />
    </div>

    <h3 class="text-lg font-semibold text-foreground mb-2">
        {title}
    </h3>

    <p
        class="text-sm text-surface-foreground/70 mb-6 flex-grow leading-relaxed"
    >
        {description}
    </p>

    <div class="flex flex-wrap gap-2">
        {
            tags.map((tag) => (
                <span class="text-[10px] px-2 py-1 rounded bg-border text-surface-foreground font-mono">
                    {tag}
                </span>
            ))
        }
    </div>
</div>
