---
interface Props {
    role: string;
    company: string;
    period: string;
    highlights: string[];
    active?: boolean;
}

const { role, company, period, highlights, active } = Astro.props;
---

<div
    class="relative pl-8 border-l border-border hover:border-primary/50 transition-colors py-2">
    <div
        class={`absolute -left-1.5 top-4 size-2 rounded-full 
    ${active ? "bg-primary ring-4 ring-primary/20" : "bg-border"}`}>
    </div>

    <div
        class="flex flex-col md:flex-row md:items-baseline justify-between mb-2">
        <h3 class="text-xl font-bold text-foreground">
            {role}
        </h3>

        <span class="text-sm text-surface-foreground/70 font-mono">
            {period}
        </span>
    </div>

    <p class="text-primary font-medium mb-4 text-sm">
        {company}
    </p>

    <ul class="space-y-2 text-foreground/60 text-sm leading-relaxed max-w-3xl">
        {highlights.map((item) => <li>• {item}</li>)}
    </ul>
</div>
