---
import SkillCard from "./SkillCard.astro";

const skills = [
    {
        title: "Infrastructure",
        icon: "cloud_queue",
        items: [
            { name: "Kubernetes & Orchestration", level: "Senior" },
            { name: "Terraform & IaC", level: "Expert" },
            { name: "CI/CD Pipelines", level: "Advanced" },
        ],
    },
    {
        title: "Development",
        icon: "code_blocks",
        items: [
            { name: "Golang / Rust", level: "Expert" },
            { name: "Distributed Systems", level: "Senior" },
            { name: "System Performance", level: "Expert" },
        ],
    },
];
---

<section class="bg-surface-dark/20 py-24" id="expertise">
    <div class="max-w-6xl mx-auto px-6">
        <div class="flex flex-col md:flex-row gap-16">
            <div class="md:w-1/3">
                <h2 class="text-2xl font-bold text-foreground mb-4">
                    Core Expertise
                </h2>

                <p class="text-foreground/60 leading-relaxed mb-6">
                    My technical stack is built on foundation of performance,
                    observability, and robust security principles.
                </p>

                <div
                    class="inline-flex items-center gap-2 text-primary font-medium text-sm"
                >
                    <span class="font-icon text-base">verified</span>
                    <span>Certified Solutions Architect</span>
                </div>
            </div>

            <div class="md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-10">
                {skills.map((skill) => <SkillCard {...skill} />)}
            </div>
        </div>
    </div>
</section>
